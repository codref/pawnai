# PawnAI configuration file
#
# 1. Copy this file to .pawnai.yml and fill in your values:
#      cp .pawnai.yml.example .pawnai.yml
#
# 2. Or point to any YAML file with --config:
#      pawnai diarize audio.wav --config /path/to/config.yml
#
# NOTE: .pawnai.yml is listed in .gitignore – never commit your tokens!
# HF_TOKEN is also read from the environment variable as a fallback,
# which is the recommended approach for CI/CD pipelines.

# ── Model settings ────────────────────────────────────────────────────────────
models:
  # HuggingFace API token for downloading gated models (pyannote.audio).
  # Get yours at: https://huggingface.co/settings/tokens
  hf_token: your_hf_token_here

  # Override default model identifiers if needed.
  # diarization_model: pyannote/speaker-diarization-community-1
  # embedding_model: pyannote/embedding
  # transcription_model: nvidia/parakeet-tdt-0.6b-v3

# ── Path settings ─────────────────────────────────────────────────────────────
paths:
  # Directory for the LanceDB speaker-embedding database.
  # db_path: speakers_db

  # Directory where audio files are stored.
  # audio_dir: audio/

# ── Device settings ───────────────────────────────────────────────────────────
device:
  # Compute device: "auto" (default), "cuda", or "cpu".
  # type: auto

# ── S3-compatible storage ─────────────────────────────────────────────────────
# When present, any audio path that starts with s3:// is transparently
# downloaded before processing and the temp file is removed afterwards.
#
# Supported URI formats:
#   s3://my-audio-bucket/recordings/call.wav   ← standard (bucket in URI)
#   s3://recordings/call.wav                   ← key-only (uses s3.bucket)
#
# Uncomment and fill in your values to enable S3 support.
# s3:
#   # Required fields
#   bucket: my-audio-bucket
#   endpoint_url: https://s3.amazonaws.com      # or MinIO / Ceph endpoint
#   access_key: AKIAIOSFODNN7EXAMPLE
#   secret_key: wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
#
#   # Optional fields
#   region: us-east-1        # AWS region; omit for non-AWS endpoints
#   prefix: ""               # prepended to every object key
#   verify_ssl: true         # set to false to skip TLS verification (dev only)
#   path_style: true         # use path-style addressing (required for MinIO)