[Unit]
Description=pawn-server HTTP API and queue listener
After=network.target postgresql.service

[Service]
Type=simple
User={{USER}}
WorkingDirectory={{PROJECT_DIR}}
ExecStart={{BIN_DIR}}/pawn-server --config {{PROJECT_DIR}}/pawnai.yaml
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
