{
  "build": { "dockerfile": "Dockerfile" },
  "runArgs": [
    "--gpus",
    "all",
    "--ulimit",
    "memlock=-1",
    "--ipc=host",
    "--ulimit",
    "stack=67108864"
], "remoteUser": "operatore",
"containerEnv": {
    "SHELL": "/bin/bash"
},
  "mounts": [
    "type=bind,source=/home/${localEnv:USER}/.ssh,target=/home/operatore/.ssh,readonly"
  ]
}